{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@tissint/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}

EXPO_PUBLIC_TISSINT_ENV=development
EXPO_PUBLIC_TISSINT_API_MODE=mock
# Android emulator: http://10.0.2.2:8000
# iOS simulator/web: http://127.0.0.1:8000
# Physical device: http://<computer-lan-ip>:8000
EXPO_PUBLIC_TISSINT_API_BASE_URL=http://127.0.0.1:8000

# Public gateway identifier only. Do not put private backend secrets in Expo public env vars.
EXPO_PUBLIC_TISSINT_API_KEY=

# Production builds must use:
# EXPO_PUBLIC_TISSINT_ENV=production
# EXPO_PUBLIC_TISSINT_API_MODE=http
# EXPO_PUBLIC_TISSINT_API_BASE_URL=https://api.tissint.ma

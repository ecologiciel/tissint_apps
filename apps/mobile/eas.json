{
  "cli": {
    "version": "20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_TISSINT_ENV": "preview",
        "EXPO_PUBLIC_TISSINT_API_MODE": "http",
        "EXPO_PUBLIC_TISSINT_API_BASE_URL": "https://api-staging.tissint.ma"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_TISSINT_ENV": "production",
        "EXPO_PUBLIC_TISSINT_API_MODE": "http",
        "EXPO_PUBLIC_TISSINT_API_BASE_URL": "https://api.tissint.ma"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

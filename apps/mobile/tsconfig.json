{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@tissint/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@tissint/api-client": [
        "../../packages/api-client/src/index.ts"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/shared/src/**/*.ts",
    "../../packages/api-client/src/**/*.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
